ANTHROPIC_API_KEY=your_api_key_here

# Supabase
# NEXT_PUBLIC_SUPABASE_URL is shared between the server client (service role)
# and the browser client (anon key). Both are required.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Email notifications (Resend) — used for new deal submission alerts
RESEND_API_KEY=
# Optional overrides (defaults shown)
# NOTIFICATION_FROM_EMAIL="Funders First <deals@fundersfirst.com>"
# NEW_DEAL_NOTIFY_TO=info@fundersfirst.com,logan@fundersfirst.com
